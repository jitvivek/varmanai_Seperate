# ============================================================
# VarmanAI Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Backend ---

# PostgreSQL connection string
DATABASE_URL=postgresql://varman:varman@localhost:5432/varmanai

# Redis connection string
REDIS_URL=redis://localhost:6379

# Clerk secret key for JWT verification (from dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_xxx

# Razorpay API credentials (from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# Razorpay webhook secret for signature verification
RAZORPAY_WEBHOOK_SECRET=xxx

# Server port
PORT=4000

# Environment: development | production
NODE_ENV=development

# Frontend URL (for CORS allowlist)
FRONTEND_URL=http://localhost:3000

# --- Website (Next.js) ---

# Clerk publishable key (client-side, starts with pk_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Clerk secret key (same as backend if shared, or separate)
# CLERK_SECRET_KEY=sk_test_xxx (already set above for monorepo)

# Backend API URL for client-side requests
NEXT_PUBLIC_API_URL=http://localhost:4000

# Razorpay key ID for checkout (client-side)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# Chrome Web Store URL (placeholder until extension is published)
NEXT_PUBLIC_CHROME_STORE_URL=https://chrome.google.com/webstore/detail/PLACEHOLDER

# Edge Add-ons Store URL (placeholder until extension is published)
NEXT_PUBLIC_EDGE_STORE_URL=https://microsoftedge.microsoft.com/addons/detail/PLACEHOLDER

# Canonical site URL for SEO
NEXT_PUBLIC_SITE_URL=https://varmanai.com

# --- Extension (build-time, injected via Vite) ---

# Backend API URL the extension connects to
VITE_API_URL=http://localhost:4000

# Website URL for auth redirects and upgrade links
VITE_WEBSITE_URL=http://localhost:3000
