{
  "name": "varmanai",
  "version": "1.0.0",
  "private": true,
  "description": "VarmanAI — Armor for your AI. Cybersecurity SaaS protecting users from harmful AI interactions.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:push": "pnpm --filter @varmanai/backend exec prisma db push",
    "db:generate": "pnpm --filter @varmanai/backend exec prisma generate",
    "db:migrate": "pnpm --filter @varmanai/backend exec prisma migrate dev"
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
